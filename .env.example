# Copy to .env.local to enable live Supabase persistence (otherwise demo mode
# stores waitlist signups in the browser's localStorage).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# For local/root hosting (not project Pages), build with an empty base path:
#   BASE_PATH= npm run build
